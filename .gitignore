# ============================================================================
# DOTFILES .gitignore
# ============================================================================

# Backups
*.bak
*.backup
*.old
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.code-workspace

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporários
*.tmp
*.temp
.cache/

# Secrets (NUNCA commitar!)
.env
.env.local
secrets/
credentials/
*.key
*.pem
*_rsa
*_dsa
*_ecdsa
*_ed25519

# Personal configs
# Descomente se quiser manter configs pessoais localmente
# .gitconfig.local
# .zshrc.local

# Zinit/Plugin caches
.zinit/
plugins/

# History files
.zsh_history
.bash_history
.lesshst

# Package manager
node_modules/
vendor/
